# Copy to `.env.local` for local dev, or set in Vercel → Project → Settings → Environment Variables (Production).

# Canonical site URL — use your real production domain so fallbacks match when
# request headers are not available (e.g. some CI builds).
NEXT_PUBLIC_SITE_URL=https://your-production-domain.com

# Optional: paste meta tag content values from Google Search Console / Bing Webmaster
# NEXT_PUBLIC_GOOGLE_SITE_VERIFICATION=
# NEXT_PUBLIC_BING_SITE_VERIFICATION=
